\begin_layout Plain Layout
for linear predictor,
 and a seed sample 
\begin_inset Formula $\mathbf{x}_{0}$
\end_inset

,
 to reach a target level 
\begin_inset Formula $r^{*}$
\end_inset

,
 
\begin_inset Formula 
\begin{align*}
 & \arg\min_{\mathbf{x}}(\hat{f}(\mathbf{x})-r^{*})^{2}+\lambda\|\mathbf{x}-\mathbf{x}_{0}\|^{2}\\
= & \arg\min_{\mathbf{x}}(\hat{\beta}^{\top}\mathbf{x}-r^{*})^{2}+\lambda\|\mathbf{x}-\mathbf{x}_{0}\|^{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
What we actually want is 
\begin_inset Formula 
\[
\min_{\mathbf{x}}\|\mathbf{x}-\mathbf{x}_{0}\|^{2}\quad\text{s.t.}\quad\hat{\beta}^{\top}\mathbf{x}=r^{*}.
\]

\end_inset


\end_layout

\begin_layout Plain Layout
Optimal solution
\begin_inset Formula 
\[
\mathbf{x}^{*}=\mathbf{x}_{0}+\Big(\frac{r^{*}-\hat{\beta}^{\top}\mathbf{x}_{0}}{\|\hat{\beta}\|^{2}}\Big)\hat{\beta}
\]

\end_inset


\end_layout

\begin_layout Plain Layout
Non isotropic prior over weights 
\begin_inset Formula 
\begin{align*}
\mathcal{L} & =p(\beta)+Likelihood(y,\mathbf{x}|\beta)\\
 & =\frac{1}{2}\frac{1}{\sigma^{2}}\mathbb{E}_{y,\mathbf{x}}\|y-\beta^{\top}\mathbf{x}\|^{2}+\frac{1}{2}\beta^{\top}\Sigma_{\beta}^{-1}\beta\\
 & =\frac{1}{2}\frac{1}{\sigma^{2}}\mathbb{E}_{y,\mathbf{x}}\Big[yy-2\beta^{\top}\mathbf{x}y+\beta^{\top}\mathbf{x}\mathbf{x}^{\top}\beta\Big]+\frac{1}{2}\beta^{\top}\Sigma_{\beta}^{-1}\beta\\
 & =\frac{1}{2}\frac{1}{\sigma^{2}}\Big[Var_{yy}-2\beta^{\top}\Sigma_{yx}+\beta^{\top}\Sigma_{xx}\beta\Big]+\frac{1}{2}\beta^{\top}\Sigma_{\beta}^{-1}\beta\\
 & =\frac{1}{2}\frac{1}{\sigma^{2}}Var_{yy}-\frac{1}{\sigma^{2}}\beta^{\top}\Sigma_{yx}+\frac{1}{2}\frac{1}{\sigma^{2}}\beta^{\top}\Sigma_{xx}\beta+\frac{1}{2}\beta^{\top}\Sigma_{\beta}^{-1}\beta\\
 & =\frac{1}{2}\frac{1}{\sigma^{2}}Var_{yy}-\frac{1}{\sigma^{2}}\beta^{\top}\Sigma_{yx}+\frac{1}{2}\beta^{\top}(\frac{1}{\sigma^{2}}\Sigma_{xx}+\Sigma_{\beta}^{-1})\beta
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
\begin_inset Formula 
\[
\nabla\mathcal{L}=-\frac{1}{\sigma^{2}}\Sigma_{yx}+(\frac{1}{\sigma^{2}}\Sigma_{xx}+\Sigma_{\beta}^{-1})\beta
\]

\end_inset


\end_layout

\begin_layout Plain Layout
Consider Gaussian prior over the weight vector,
 but non isotropic.
 
\begin_inset Formula 
\begin{align*}
\beta^{*} & =(\frac{1}{\sigma^{2}}\Sigma_{xx}+\Sigma_{\beta}^{-1})^{-1}\frac{1}{\sigma^{2}}\Sigma_{yx}\\
 & =(\Sigma_{xx}+\sigma^{2}\Sigma_{\beta}^{-1})^{-1}\Sigma_{yx}
\end{align*}

\end_inset


\end_layout

\begin_layout Plain Layout
One special case is to let weight conform to the natural data statistics,
 i.e.
 
