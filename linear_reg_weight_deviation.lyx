\beta^{*} & =\sum_{k}\mathbf{u}_{k}(\lambda_{k}+\frac{\sigma^{2}}{\lambda_{k}})^{-1}\mathbf{u}_{k}^{\top}\Sigma_{yx}\\
 & =\sum_{k}\mathbf{u}_{k}\frac{1}{\lambda_{k}+\frac{\sigma^{2}}{\lambda_{k}}}\mathbf{u}_{k}^{\top}\Sigma_{yx}\\
 & =\sum_{k}\mathbf{u}_{k}\frac{\lambda_{k}}{\lambda_{k}^{2}+\sigma^{2}}\mathbf{u}_{k}^{\top}\Sigma_{yx}\\
\end{align*}

\end_inset


\end_layout

